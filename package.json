{
  "name": "jami-flashcards",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:clean": "npm run clean && next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm test",
    "test:rules": "firebase emulators:exec --only firestore,storage \"vitest run --config vitest.rules.config.ts\"",
    "emulators:rules": "firebase emulators:start --only firestore,storage",
    "firebase:login": "firebase login",
    "firebase:projects": "firebase projects:list",
    "firebase:rules:deploy": "firebase deploy --only firestore:rules,storage"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.1.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^13.10.0",
    "js-draw": "^1.33.0",
    "katex": "^0.18.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.11",
    "officeparser": "^7.2.1",
    "pdfjs-dist": "^6.0.227",
    "perfect-freehand": "^1.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "ts-fsrs": "^5.3.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^22",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "firebase-tools": "^15.24.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "protobufjs": "7.6.5",
    "tar": "7.5.19",
    "websocket-driver": "0.7.5"
  }
}
