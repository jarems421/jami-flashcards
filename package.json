{
  "name": "jami-flashcards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:clean": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\" && next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts\"",
    "emulators:firestore": "firebase emulators:start --only firestore",
    "firebase:login": "firebase login",
    "firebase:projects": "firebase projects:list",
    "firebase:rules:deploy": "firebase deploy --only firestore"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "next": "^16.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "ts-fsrs": "^5.3.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^20",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "firebase-tools": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
