// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deck {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  parentDeckId     String?  @db.Uuid
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  settingsOverride Json?

  parentDeck Deck?  @relation("DeckToDeck", fields: [parentDeckId], references: [id])
  subDecks   Deck[] @relation("DeckToDeck")
  cards      Card[]
  notes      Note[]
  studyGoals StudyGoal[]
  reminders  Reminder[]
}

model Note {
  id         String   @id @default(uuid()) @db.Uuid
  deckId     String   @db.Uuid
  noteTypeId String   @db.Uuid
  fields     Json
  tags       String[]
  media      Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deck     Deck     @relation(fields: [deckId], references: [id])
  noteType NoteType @relation(fields: [noteTypeId], references: [id])
  cards    Card[]
}

model Card {
  id                String    @id @default(uuid()) @db.Uuid
  noteId            String    @db.Uuid
  deckId            String    @db.Uuid
  templateId        String
  state             CardState
  reps              Int       @default(0)
  lastReviewedAt    DateTime?

  note      Note        @relation(fields: [noteId], references: [id])
  deck      Deck        @relation(fields: [deckId], references: [id])
  reviewLogs ReviewLog[]
  template  Template    @relation(fields: [templateId], references: [id])
}

model ReviewLog {
  id                   String      @id @default(uuid()) @db.Uuid
  cardId               String      @db.Uuid
  reviewedAt           DateTime    @default(now())
  rating               ReviewRating
  responseTimeMs       Int         @default(0)

  card Card @relation(fields: [cardId], references: [id])
}

model NoteType {
  id     String   @id @default(uuid()) @db.Uuid
  name   String
  fields String[]

  notes     Note[]
  templates Template[]
}

model Template {
  id          String @id
  noteTypeId  String @db.Uuid
  frontHTML   String
  backHTML    String

  noteType NoteType @relation(fields: [noteTypeId], references: [id])
  cards    Card[]
}

enum CardState {
  NEW
  STUDIED
}

enum ReviewRating {
  WRONG
  CORRECT
}

enum GoalCadence {
  DAILY
  WEEKLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model StudyGoal {
  id            String      @id @default(uuid()) @db.Uuid
  deckId        String?     @db.Uuid
  cadence       GoalCadence @default(DAILY)
  targetCount   Int         @default(20)
  targetAccuracy Int?       @default(80)
  deadline      DateTime?
  status        GoalStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  deck          Deck?       @relation(fields: [deckId], references: [id])
  progress      GoalProgress[]
}

model GoalProgress {
  id            String      @id @default(uuid()) @db.Uuid
  goalId        String      @db.Uuid
  dateBucket    DateTime    @db.Date
  completedCount Int        @default(0)
  createdAt     DateTime    @default(now())

  goal          StudyGoal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([goalId, dateBucket])
}

model Reminder {
  id            String      @id @default(uuid()) @db.Uuid
  deckId        String?     @db.Uuid
  goalId        String?     @db.Uuid
  message       String?
  sendAt        DateTime
  isRecurring   Boolean     @default(false)
  recurrencePattern String?
  isSent        Boolean     @default(false)
  createdAt     DateTime    @default(now())

  deck          Deck?       @relation(fields: [deckId], references: [id])
}

model UserPreference {
  id                  String   @id @default(uuid()) @db.Uuid
  timezone            String   @default("UTC")
  dailyReminderTime   String?
  emailReminders      Boolean  @default(true)
  inAppReminders      Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
